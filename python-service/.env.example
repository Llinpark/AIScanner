# Primary market data provider
MARKET_DATA_PRIMARY=twelve_data
MARKET_DATA_FALLBACK=eodhd

# Twelve Data (primary)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
# TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# EODHD (automatic fallback)
EODHD_API_KEY=your_eodhd_api_key_here
# EODHD_BASE_URL=https://eodhd.com/api

# Cache
MARKET_DATA_CACHE_TTL_SECONDS=60
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0

# WebSocket streaming (Twelve Data relay)
MARKET_DATA_STREAM_ENABLED=true
