JWT_SECRET=your_jwt_secret_change_in_production
# Generate local secrets: npm run generate-secrets
# Local: mongodb://127.0.0.1:27017/kachingscanner
# Atlas (free M0): mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kachingscanner
MONGODB_URI=mongodb://127.0.0.1:27017/kachingscanner
PORT=4000

# Custom domain (production)
APP_DOMAIN=kachingscanner.com
# Local dev:
FRONTEND_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:4000
# Production (set NODE_ENV=production or override explicitly):
# FRONTEND_URL=https://kachingscanner.com
# PUBLIC_BACKEND_URL=https://api.kachingscanner.com
# Optional extra CORS origins (comma-separated): https://www.kachingscanner.com

# Shared webhook signing secret (HMAC + license tokens). Falls back to TRADINGVIEW_WEBHOOK_SECRET / JWT_SECRET.
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
# Legacy global secret for broadcast/system alerts without userId (disabled in production unless ALLOW_LEGACY_WEBHOOK_SECRET=true)
TRADINGVIEW_WEBHOOK_SECRET=your_tradingview_webhook_secret_here
# Required for /api/webhook/payments in production
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret_here
# Required for Telegram webhook in production
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here
# Production cookie domain for api + app subdomains (optional): .kachingscanner.com
# COOKIE_DOMAIN=.kachingscanner.com
# TradingView OAuth callback (defaults to https://api.kachingscanner.com/api/tradingview/oauth-callback in production)
# TRADINGVIEW_REDIRECT_URI=https://api.kachingscanner.com/api/tradingview/oauth-callback
SCANNER_AUTO_ENABLED=true
SCANNER_INTERVAL_MS=300000
SCANNER_BATCH_SIZE=5
# Minimum weighted pipeline score (0-100) to publish scanner entries. Default: 80
# SCANNER_PREMIUM_THRESHOLD=80

# Weight learning from TP/SL outcomes (Node-only). Interval 0 = off.
# Positive credit: TP1=1R, TP2=2R, TP3=3R; negative: SL=-1R. Debounce batches closes.
# LEARNING_RETRAIN_INTERVAL_MS=86400000
# LEARNING_OUTCOME_DEBOUNCE_MS=60000
# LEARNING_MIN_SAMPLES=20
# LEARNING_RATE=0.35
# LEARNING_FACTOR_ACTIVE_THRESHOLD=50

# Email (verification + password reset). Without SMTP, links are logged to the backend console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=KachingScanner <noreply@kachingscanner.com>

# ADMIN_EMAILS=admin1@example.com,admin2@example.com
# SUPER_ADMIN_EMAILS=superadmin@example.com

# Beta launch: auto sign-in on register, skip email verify, grant tier access
# BETA_MODE=true
# BETA_TIER=premium
# BETA_ACCESS_DAYS=30

# Market data: Twelve Data primary, EODHD automatic fallback, mock for local dev without keys
DATA_PROVIDER=twelve_data
MARKET_DATA_PRIMARY=twelve_data
MARKET_DATA_FALLBACK=eodhd
MARKET_DATA_CACHE_TTL_MS=60000
MARKET_DATA_STALE_TTL_MS=900000
# Minimum gap between provider API calls during live polling (ms). Default: 9000
# MARKET_DATA_MIN_FETCH_GAP_MS=9000
# Cooldown after Twelve Data rate-limit (429). Default: 65000
# MARKET_DATA_RATE_LIMIT_COOLDOWN_MS=65000
# Cap Twelve Data calls/min to stay under free-tier 8 credits/min. Default: 7
# TWELVE_DATA_CREDITS_PER_MINUTE=7
# Demand-driven refresh per viewed symbol+timeframe (see backend/utils/marketIntervals.js)
# Redis cache (Upstash or local). Use rediss:// for TLS (Upstash).
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_INSTANCE.upstash.io:6379
REDIS_ENABLED=true
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
EODHD_API_KEY=your_eodhd_api_key_here
# TWELVE_DATA_BASE_URL=https://api.twelvedata.com
# EODHD_BASE_URL=https://eodhd.com/api
# MARKET_DATA_CACHE_TTL_MS=60000
# FastAPI market data service (Twelve Data candles + live WS)
PYTHON_SERVICE_URL=http://localhost:8001

# Payment mode: mock | live (mock is blocked automatically when NODE_ENV=production)
PAYMENTS_MODE=mock
# Never set in production:
# ALLOW_MOCK_PAYMENTS=true
# ALLOW_LEGACY_WEBHOOK_SECRET=true

# M-Pesa Daraja STK Push (Till number: 5337170)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=5337170
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:4000/api/webhook/mpesa
# Production: https://api.kachingscanner.com/api/webhook/mpesa

# PayPal / Card payments
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
# Set PAYPAL_WEBHOOK_ID after creating the webhook in PayPal Developer Dashboard

# Binance Pay (crypto — USDT pricing mirrors PayPal USD amounts)
BINANCE_PAY_MERCHANT_ID=484947783
BINANCE_PAY_API_KEY=
BINANCE_PAY_API_SECRET=
BINANCE_PAY_ENVIRONMENT=sandbox
# BINANCE_PAY_WEBHOOK_URL=https://api.kachingscanner.com/api/webhook/binance

# SasaPay (Kenya — KES, STK-style phone prompt)
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
SASAPAY_MERCHANT_CODE=
SASAPAY_NETWORK_CODE=63902
SASAPAY_CURRENCY=KES
SASAPAY_BASE_URL=https://sandbox.sasapay.app/api/v1
# Production: set SASAPAY_BASE_URL to your SasaPay production API host
# SASAPAY_CALLBACK_URL=https://api.kachingscanner.com/api/webhook/sasapay

# Telegram bot (Pro/Premium alert delivery + Premium trade copier)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=KachingFx_Official
# Local dev: true (uses getUpdates polling). Production: false and set webhook to https://api.kachingscanner.com/api/webhook/telegram
TELEGRAM_USE_POLLING=true
TELEGRAM_WEBHOOK_SECRET=

# MT5 Trade Copier (Premium) — EA polls /api/mt5/bridge with X-MT5-Token header
# Users generate link tokens in the dashboard; no server-side broker credentials required.
MT5_DEFAULT_RISK_PERCENT=1

# Referral program — 15% first subscription payment, 5% each renewal
REFERRAL_COMMISSION_FIRST_RATE=0.15
REFERRAL_COMMISSION_RENEWAL_RATE=0.05
