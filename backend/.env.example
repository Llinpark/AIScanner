JWT_SECRET=your_jwt_secret_change_in_production
# Local: mongodb://127.0.0.1:27017/kachingscanner
# Atlas (free M0): mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kachingscanner
MONGODB_URI=mongodb://127.0.0.1:27017/kachingscanner
PORT=4000

# Custom domain (production)
APP_DOMAIN=kachingscanner.com
# Local dev:
FRONTEND_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:4000
# Production (set NODE_ENV=production or override explicitly):
# FRONTEND_URL=https://kachingscanner.com
# PUBLIC_BACKEND_URL=https://api.kachingscanner.com
# Optional extra CORS origins (comma-separated): https://www.kachingscanner.com

# Shared webhook signing secret (HMAC + license tokens). Falls back to TRADINGVIEW_WEBHOOK_SECRET / JWT_SECRET.
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
# Legacy global secret for broadcast/system alerts without userId
TRADINGVIEW_WEBHOOK_SECRET=your_tradingview_webhook_secret_here
# TradingView OAuth callback (defaults to https://api.kachingscanner.com/api/tradingview/oauth-callback in production)
# TRADINGVIEW_REDIRECT_URI=https://api.kachingscanner.com/api/tradingview/oauth-callback
SCANNER_AUTO_ENABLED=true
SCANNER_INTERVAL_MS=300000
SCANNER_BATCH_SIZE=2

# Market data: Twelve Data primary, EODHD automatic fallback, mock for local dev without keys
DATA_PROVIDER=twelve_data
MARKET_DATA_PRIMARY=twelve_data
MARKET_DATA_FALLBACK=eodhd
MARKET_DATA_CACHE_TTL_MS=300000
MARKET_DATA_STALE_TTL_MS=900000
# Demand-driven refresh per viewed symbol+timeframe (see backend/utils/marketIntervals.js)
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_ENABLED=true
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
EODHD_API_KEY=your_eodhd_api_key_here
# TWELVE_DATA_BASE_URL=https://api.twelvedata.com
# EODHD_BASE_URL=https://eodhd.com/api
# MARKET_DATA_CACHE_TTL_MS=60000
# FastAPI market data service (Twelve Data candles + live WS)
PYTHON_SERVICE_URL=http://localhost:8001

# Payment mode: mock | live (mock skips real gateway calls when credentials are missing)
PAYMENTS_MODE=mock

# M-Pesa Daraja STK Push (Till number: 5337170)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=5337170
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:4000/api/webhook/mpesa
# Production: https://api.kachingscanner.com/api/webhook/mpesa

# PayPal / Card payments
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# Telegram bot (Pro/Premium alert delivery + Premium trade copier)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=KachingScannerBot
# Local dev: true (uses getUpdates polling). Production: false and set webhook to https://api.kachingscanner.com/api/webhook/telegram
TELEGRAM_USE_POLLING=true
TELEGRAM_WEBHOOK_SECRET=

# MT5 Trade Copier (Premium) — EA polls /api/mt5/bridge with X-MT5-Token header
# Users generate link tokens in the dashboard; no server-side broker credentials required.
MT5_DEFAULT_RISK_PERCENT=1
